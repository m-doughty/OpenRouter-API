use Test;
use lib 'lib';

use OpenRouter::API::Result::Endpoint;
use JSON::Fast;

# Covers Result::Endpoint across both code paths that emit it:
# /models/{author}/{slug}/endpoints (under data.endpoints) and
# /endpoints/zdr (under data directly).

plan 4;

my %model-endpoints = from-json(slurp 't/fixtures/model-endpoints.json')<data>;
my @endpoints = %model-endpoints<endpoints>.map({
    OpenRouter::API::Result::Endpoint.new(:data($_));
});

my @zdr = from-json(slurp 't/fixtures/endpoints-zdr.json')<data>.map({
    OpenRouter::API::Result::Endpoint.new(:data($_));
});

subtest 'model-endpoints: basic fields' => {
    plan 7;
    ok @endpoints.elems > 0,                  'endpoints parsed';
    my $e = @endpoints.head;
    ok $e.provider-name.chars > 0,            'provider-name populated';
    ok $e.model-id.chars > 0,                 'model-id populated';
    ok $e.context-length > 0,                 'context-length populated';
    isa-ok $e.input-price-per-token,  Rat,    'input price as Rat';
    isa-ok $e.output-price-per-token, Rat,    'output price as Rat';
    ok $e.raw ~~ Hash,                        '.raw returns Hash';
};

subtest 'uptime + latency windows (snake_case names)' => {
    plan 4;
    my $e = @endpoints.head;
    cmp-ok $e.uptime_last_30m, '>=', 0,       'uptime_last_30m >= 0';
    cmp-ok $e.uptime_last_30m, '<=', 100,     'uptime_last_30m <= 100';
    cmp-ok $e.uptime_last_1d,  '>=', 0,       'uptime_last_1d >= 0';
    ok $e.supports-implicit-caching ~~ Bool,  'supports-implicit-caching is Bool';
};

subtest 'cache pricing when present' => {
    plan 2;
    my $e = @endpoints.head;
    my $cr = $e.input-cache-read-price-per-token;
    my $cw = $e.input-cache-write-price-per-token;
    # Claude Opus 4.7 fixture has both fields; just assert they're
    # numeric and non-negative when present.
    ok !$cr.defined || $cr >= 0, 'cache-read price absent or non-negative';
    ok !$cw.defined || $cw >= 0, 'cache-write price absent or non-negative';
};

subtest 'zdr: emitted via the same class' => {
    plan 3;
    ok @zdr.elems > 0,                    'zdr endpoints parsed';
    my $z = @zdr.head;
    ok $z.provider-name.chars > 0,        'zdr endpoint has provider-name';
    ok $z.context-length > 0,             'zdr endpoint has context-length';
};
